@echo off
setlocal
cd /d "%~dp0"
echo ============================================================
echo Install isolated external SAM2 runtime
echo ============================================================
set PYEXE=
if exist "%LOCALAPPDATA%\Programs\Python\Python312\python.exe" set PYEXE=%LOCALAPPDATA%\Programs\Python\Python312\python.exe
if "%PYEXE%"=="" set PYEXE=python
echo If installation was previously broken, delete runtime_sam2 folder before running this.
"%PYEXE%" "%~dp0scripts\install_external_sam2_runtime.py" --root "%~dp0runtime_sam2" --model base_plus
echo.
echo Finished. Press any key.
pause >nul
